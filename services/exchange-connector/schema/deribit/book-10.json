{
    "type": "object",
    "required": [
        "timestamp",
        "change_id",
        "instrument_name",
        "bids",
        "asks"
    ],
    "properties": {
        "timestamp": {
            "type": "integer",
            "description": "Unix epoch in milliseconds",
            "minimum": 1000000000000,
            "maximum": 9999999999999
        },
        "change_id": {
            "type": "integer",
            "description": "Change ID",
            "minimum": 0
        },
        "instrument_name": {
            "type": "string",
            "description": "Name of the instrument"
        },
        "bids": {
            "type": "array",
            "description": "Bid levels, each [price, quantity]",
            "minItems": 0,
            "maxItems": 10,
            "items": {
                "type": "array",
                "items": [
                    {"type": "number", "description": "price"},
                    {"type": "number", "description": "quantity"}
                ],
                "minItems": 2,
                "maxItems": 2
            }
        },
        "asks": {
            "type": "array",
            "description": "Ask levels, each [price, quantity]",
            "minItems": 0,
            "maxItems": 10,
            "items": {
                "type": "array",
                "items": [
                    {"type": "number", "description": "price"},
                    {"type": "number", "description": "quantity"}
                ],
                "minItems": 2,
                "maxItems": 2
            }
        }
    }
}